{
  "name": "waifu-library",
  "private": true,
  "version": "1.0.0",
  "description": "A desktop app to manage your program library",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "sanqbear",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc -b && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "build:win": "npm run build && npx electron-builder --win",
    "build:dir": "npm run build && npx electron-builder --win --dir",
    "build:portable": "npm run build && npx electron-builder --win portable"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "electron-log": "^5.4.3",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "vue": "^3.5.24",
    "vue-advanced-cropper": "^2.8.9",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  },
  "build": {
    "appId": "com.waifu-library.app",
    "productName": "Waifu Library",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
